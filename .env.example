# ─── Sepolia Testnet ──────────────────────────────────────────────────────────
# RPC endpoint for Sepolia (public RPC used by default, but a private one is faster)
NEXT_PUBLIC_RPC_URL="https://ethereum-sepolia-rpc.publicnode.com"

# WalletConnect project ID (get one at https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""

# Sepolia relayer URL — absolute http(s) only.
# Unset in browser = same-origin proxy at {origin}/api/relayer/11155111 (default).
# NEXT_PUBLIC_RELAYER_URL="https://your-app.vercel.app/api/relayer/11155111"

# ─── Ethereum Mainnet ─────────────────────────────────────────────────────────
# RPC endpoint for Ethereum mainnet (public fallback: llamarpc.com)
NEXT_PUBLIC_MAINNET_RPC_URL="https://eth.llamarpc.com"

# Mainnet relayer URL — absolute http(s) only.
# Unset in browser = same-origin proxy at {origin}/api/relayer/1.
# Upstream Zama mainnet relayer may return 403 until provisioned.
# NEXT_PUBLIC_MAINNET_RELAYER_URL="https://your-app.vercel.app/api/relayer/1"

# Server-side upstream for mainnet proxy (optional; not exposed to client).
# MAINNET_RELAYER_URL="https://relayer.mainnet.zama.org/v2"
