{
  "name": "macetz-dev-guide",
  "private": true,
  "version": "1.0.0",
  "description": "Deploy your own ERC-20 + ERC-7984 pair for Macetz extensibility testing",
  "scripts": {
    "compile": "hardhat compile",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
